def ensure_dir(p: str | Path) -> None:
    Path(p).mkdir(parents=True, exist_ok=True)

def print_header(title: str) -> None:
    print("\n" + "=" * 70)
    print(title)
    print("=" * 70)

def cast_nodes_lazy(nodes_path: str) -> pl.LazyFrame:
    return (
        pl.scan_parquet(nodes_path)
        .with_columns([
            pl.col("comid").cast(pl.Int32),
            pl.col("date").cast(pl.Date),
        ])
    )

def replace_sentinel_with_null(lf: pl.LazyFrame, cols: list[str], sentinel: float = SENTINEL_MISS) -> pl.LazyFrame:
    exprs = []
    for c in cols:
        exprs.append(
            pl.when(pl.col(c) == sentinel)
              .then(None)
              .otherwise(pl.col(c))
              .alias(c)
        )
    return lf.with_columns(exprs)

def assert_required_columns(lf: pl.LazyFrame, required: set[str]) -> None:
    cols = set(lf.collect_schema().names())
    missing = sorted(list(required - cols))
    if missing:
        raise ValueError("Missing required columns in nodes parquet:\n" + "\n".join(missing))


