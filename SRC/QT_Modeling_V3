class NodeSeqDataset(Dataset):
    """
    Produces:
      x_win: [N, LOOKBACK, F]
      y_t  : [N, 2]
      q_m  : [N] bool  (Q availability mask at prediction time)
      t_m  : [N] bool  (Temp availability mask at prediction time)
    """
    def __init__(self, X_TNF, Y_TN2, Qmask_TN, Tmask_TN, lookback):
        self.X = X_TNF
        self.Y = Y_TN2
        self.QM = Qmask_TN
        self.TM = Tmask_TN
        self.lb = lookback

    def __len__(self):
        return self.X.shape[0] - self.lb

    def __getitem__(self, idx):
        t = idx + self.lb
        t0 = t - self.lb + 1
        t1 = t + 1

        x_win = self.X[t0:t1, :, :]                               # [lb, N, F]
        x_win = np.transpose(x_win, (1, 0, 2)).astype(np.float32)  # [N, lb, F]
        y_t   = self.Y[t, :, :].astype(np.float32)                 # [N, 2]
        q_m   = self.QM[t, :].astype(bool)                         # [N]
        t_m   = self.TM[t, :].astype(bool)                         # [N]
        return (
            torch.from_numpy(x_win),
            torch.from_numpy(y_t),
            torch.from_numpy(q_m),
            torch.from_numpy(t_m),
        )


# -------------------------
# Model: LSTM + Temporal Attention, two-output head
# -------------------------
class TemporalAttention(nn.Module):
    """
    Attention over time dimension for each node independently.
    Input:  h_seq [N, L, H]
    Output: ctx  [N, H]
    """
    def __init__(self, hidden_dim: int):
        super().__init__()
        self.score = nn.Linear(hidden_dim, 1)

    def forward(self, h_seq: torch.Tensor) -> torch.Tensor:
        logits = self.score(h_seq).squeeze(-1)           # [N, L]
        alpha  = torch.softmax(logits, dim=1)            # [N, L]
        ctx    = torch.sum(h_seq * alpha.unsqueeze(-1), dim=1)  # [N, H]
        return ctx


class LSTM_Attn_MTL(nn.Module):
    def __init__(self, in_dim, lstm_hidden, lstm_layers, lstm_dropout, out_dim=2):
        super().__init__()
        self.lstm = nn.LSTM(
            input_size=in_dim,
            hidden_size=lstm_hidden,
            num_layers=lstm_layers,
            dropout=(lstm_dropout if lstm_layers > 1 else 0.0),
            batch_first=True
        )
        self.drop = nn.Dropout(lstm_dropout)
        self.attn = TemporalAttention(lstm_hidden)
        self.head = nn.Linear(lstm_hidden, out_dim)

    def forward(self, x_win: torch.Tensor) -> torch.Tensor:
        # x_win: [N, L, F]
        h_seq, _ = self.lstm(x_win)  # [N, L, H]
        h_seq = self.drop(h_seq)
        ctx = self.attn(h_seq)       # [N, H]
        return self.head(ctx)        # [N, 2]


