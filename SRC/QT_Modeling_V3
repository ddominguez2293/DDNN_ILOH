#     each column using only its observed subset via separate scalers to avoid bias.
scaler_y_q = MinMaxScaler()
scaler_y_t = MinMaxScaler()

Y_train = Y_TN2[train_mask_rows]  # [Ttrain, N, 2]

# Fit Q scaler on observed Q only
q_obs = Y_train[:, :, 0][Qmask_TN[train_mask_rows]].reshape(-1, 1)
if q_obs.size == 0:
    raise ValueError("No observed Q values in training period (check Q_COL and SPLIT_DATE).")
scaler_y_q.fit(q_obs.astype(np.float32))

# Fit T scaler on observed Temp only
t_obs = Y_train[:, :, 1][Tmask_TN[train_mask_rows]].reshape(-1, 1)
if t_obs.size == 0:
    print("WARNING: No observed temperature values in training period. Temp head will be effectively unused.")
    # Fit on a dummy value to keep code running; loss will mask T out anyway.
    scaler_y_t.fit(np.array([[0.0]], dtype=np.float32))
