def safe_parity_scatter(true_vals, pred_vals, title, xlabel, ylabel, mask=None, max_points=250_000):
    true_vals = np.asarray(true_vals).ravel()
    pred_vals = np.asarray(pred_vals).ravel()

    if mask is not None:
        mask = np.asarray(mask).ravel().astype(bool)
        true_vals = true_vals[mask]
        pred_vals = pred_vals[mask]

    valid = np.isfinite(true_vals) & np.isfinite(pred_vals)
    true_vals = true_vals[valid]
    pred_vals = pred_vals[valid]

    n = true_vals.size
    if n > max_points:
        idx = np.random.choice(n, size=max_points, replace=False)
        true_vals = true_vals[idx]
        pred_vals = pred_vals[idx]

    plt.figure(figsize=(5, 5))
    plt.scatter(true_vals, pred_vals, alpha=0.3, s=10)
    mx = max(true_vals.max(), pred_vals.max())
    mn = min(true_vals.min(), pred_vals.min())
    plt.plot([mn, mx], [mn, mx], linestyle="--")
    plt.xlabel(xlabel)
    plt.ylabel(ylabel)
    plt.title(title)
