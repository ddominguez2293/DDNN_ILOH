# -------------------------
# Training loop
# -------------------------
print_header("TRAINING")
best_val = float("inf")
best_state = None
epochs_no_improve = 0

print(f"Training on {len(train_ds)} steps; validating on {len(test_ds)} steps.")
for epoch in range(1, EPOCHS + 1):
    model.train()
    tr_losses = []; tr_q = []; tr_t = []

    for x_win, y_t, q_m, t_m in train_loader:
        x_win = x_win.squeeze(0).to(device).float()  # [N, L, F]
        y_t   = y_t.squeeze(0).to(device).float()    # [N, 2]
        q_m   = q_m.squeeze(0).to(device)            # [N]
        t_m   = t_m.squeeze(0).to(device)            # [N]

        optimizer.zero_grad()
        yhat = model(x_win)  # [N, 2]
        loss, lq, lt = nse_mse_mixed_loss(yhat, y_t, TASK_WEIGHTS, q_mask=q_m, t_mask=t_m)
        loss.backward()
        optimizer.step()

        tr_losses.append(loss.item()); tr_q.append(lq.item()); tr_t.append(lt.item())

    model.eval()
    va_losses = []; va_q = []; va_t = []
    with torch.no_grad():
        for x_win, y_t, q_m, t_m in test_loader:
            x_win = x_win.squeeze(0).to(device).float()
            y_t   = y_t.squeeze(0).to(device).float()
            q_m   = q_m.squeeze(0).to(device)
            t_m   = t_m.squeeze(0).to(device)

            yhat = model(x_win)
            loss, lq, lt = nse_mse_mixed_loss(yhat, y_t, TASK_WEIGHTS, q_mask=q_m, t_mask=t_m)
            va_losses.append(loss.item()); va_q.append(lq.item()); va_t.append(lt.item())

    tr_mean = float(np.mean(tr_losses)); va_mean = float(np.mean(va_losses))
    print(f"Epoch {epoch:03d}/{EPOCHS} | Train mix: {tr_mean:.6f} "
          f"(Q NSEterm {np.mean(tr_q):.6f}, T MSE {np.mean(tr_t):.6f}) "
          f"| Val mix: {va_mean:.6f} (Q NSEterm {np.mean(va_q):.6f}, T MSE {np.mean(va_t):.6f})")

    scheduler.step(va_mean)

    if va_mean + 1e-6 < best_val:
        best_val = va_mean
        best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}
        epochs_no_improve = 0
    else:
        epochs_no_improve += 1
        if epochs_no_improve >= PATIENCE:
            print(f"Early stopping at epoch {epoch}")
            break

if best_state is not None:
    model.load_state_dict(best_state)
    model.to(device)

# -------------------------
# Inverse transforms (task-specific scalers)
# -------------------------
def inverse_two_columns_by_task(arr_scaled_TN2: np.ndarray) -> np.ndarray:
    """
    arr_scaled_TN2: [T, N, 2] in scaled space
    Returns:        [T, N, 2] in physical units (but only valid where masks are True)
    Missing entries will be inverse-transformed from 0.0; you MUST use masks when evaluating.
    """
    out = np.zeros_like(arr_scaled_TN2, dtype=np.float32)

    q_flat = arr_scaled_TN2[:, :, 0].reshape(-1, 1)
    t_flat = arr_scaled_TN2[:, :, 1].reshape(-1, 1)

    out[:, :, 0] = scaler_y_q.inverse_transform(q_flat).reshape(arr_scaled_TN2.shape[0], arr_scaled_TN2.shape[1]).astype(np.float32)
    out[:, :, 1] = scaler_y_t.inverse_transform(t_flat).reshape(arr_scaled_TN2.shape[0], arr_scaled_TN2.shape[1]).astype(np.float32)
    return out

def nse_numpy(sim, obs):
    num = np.sum((sim - obs) ** 2)
    den = np.sum((obs - np.mean(obs)) ** 2) + 1e-12
    return 1.0 - num / den

def rmse_numpy(sim, obs):
    return float(np.sqrt(np.mean((sim - obs) ** 2)))

def mae_numpy(sim, obs):
    return float(np.mean(np.abs(sim - obs)))

