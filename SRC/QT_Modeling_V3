    scaler_y_t.fit(t_obs.astype(np.float32))

# Transform Y into scaled space with masks; missing entries get filled to 0.0 AFTER scaling
Y_scaled = np.zeros_like(Y_TN2, dtype=np.float32)

# Q column transform where observed
q_all = Y_TN2[:, :, 0]
