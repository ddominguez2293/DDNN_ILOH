# --- X scaler: same approach as before (fill null/nan to 0 for features)
scaler_X = MinMaxScaler()
fit_X = np.nan_to_num(X_TNF[train_mask_rows].reshape(-1, Fdim), nan=0.0)
scaler_X.fit(fit_X)

X_TNF = scaler_X.transform(np.nan_to_num(X_TNF.reshape(-1, Fdim), nan=0.0)).reshape(Tsteps, N, Fdim).astype(np.float32)

# --- y scaler: fit ONLY on observed targets in TRAIN period
