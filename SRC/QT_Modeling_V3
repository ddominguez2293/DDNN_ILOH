# -------------------------
# Loss helpers (masked targets)
# -------------------------
Q_EPS = 1e-6

def nse_mse_mixed_loss(yhat, ytrue, w, q_mask=None, t_mask=None, eps=1e-8):
    """
    yhat, ytrue: [N, 2] (scaled space)
    q_mask: [N] bool, True where Q is observed at this time step
    t_mask: [N] bool, True where Temp is observed at this time step

    Q loss: weighted NSE-like term computed only where q_mask is True AND q_true>eps
    T loss: MSE computed only where t_mask is True
    """
    w = w.to(yhat.device)

    # ---- Q: masked weighted NSE term ----
    q_pred = yhat[:, 0]
    q_true = ytrue[:, 0]

    if q_mask is None:
        q_mask = torch.ones_like(q_true, dtype=torch.bool)

    # Also require q_true>eps to avoid "fake zeros" even if present
    q_use = q_mask & (q_true > Q_EPS)

    if q_use.sum() == 0:
        nse_term_q = torch.tensor(0.0, device=yhat.device)
        w_q = torch.tensor([0.0, 1.0], device=yhat.device)  # effectively ignore Q
    else:
        q_true_u = q_true[q_use]
        q_pred_u = q_pred[q_use]
        q_mean = torch.mean(q_true_u)
        num_q = torch.sum((q_true_u - q_pred_u) ** 2)
        den_q = torch.sum((q_true_u - q_mean) ** 2) + eps
        nse_term_q = num_q / den_q
        w_q = w

    # ---- Temp: masked MSE ----
    if t_mask is None:
        t_mask = torch.ones_like(q_true, dtype=torch.bool)

    if t_mask.sum() == 0:
        mse_t = torch.tensor(0.0, device=yhat.device)
        w_use = torch.tensor([1.0, 0.0], device=yhat.device) if (q_use.sum() > 0) else torch.tensor([0.0, 1.0], device=yhat.device)
    else:
        t_pred = yhat[t_mask, 1]
        t_true = ytrue[t_mask, 1]
        mse_t = torch.mean((t_true - t_pred) ** 2)
        w_use = w_q

    w_use = w_use / (w_use.sum() + eps)
    total = w_use[0] * nse_term_q + w_use[1] * mse_t
    return total, nse_term_q.detach(), mse_t.detach()


